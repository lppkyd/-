/* 全局样式 */
page {
  background-color: #F3F4F6;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica', 'Arial', sans-serif;
  height: 100%;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* 按钮样式 */
.btn-primary {
  background-color: #4F46E5;
  color: white;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  border: none;
}

.btn-secondary {
  background-color: white;
  color: #4F46E5;
  border: 2rpx solid #4F46E5;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
}

.btn-danger {
  background-color: #EF4444;
  color: white;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  border: none;
}

/* 卡片样式 */
.card {
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 文本样式 */
.text-large {
  font-size: 48rpx;
  font-weight: 600;
}

.text-medium {
  font-size: 32rpx;
}

.text-small {
  font-size: 28rpx;
  color: #6B7280;
}

.text-primary {
  color: #4F46E5;
}

.text-success {
  color: #10B981;
}

.text-danger {
  color: #EF4444;
}

.text-muted {
  color: #9CA3AF;
}
