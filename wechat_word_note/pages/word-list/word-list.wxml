<view class="page">
  <view class="header">
    <view class="header__title">{{dictInfo ? dictInfo.name : '单词列表'}}</view>
    <view class="header__sub">{{dictInfo ? dictInfo.description : '正在加载中...'}}</view>
  </view>

  <view class="action-bar">
    <button class="btn" bindtap="goTyping">开始学习</button>
  </view>

  <view class="word-list">
    <view class="word-card" wx:for="{{words}}" wx:key="index">
      <view class="word-card__main">
        <view class="word-card__word">{{item.name || item.word}}</view>
        <view class="word-card__trans">{{item.trans ? item.trans.join('；') : item.meaning}}</view>
      </view>
      <view class="word-card__extra" wx:if="{{item.example}}">例句：{{item.example}}</view>
      <view class="word-card__actions">
        <button size="mini" bindtap="saveToWords" data-word="{{item}}">保存生词</button>
      </view>
    </view>
  </view>
</view>
