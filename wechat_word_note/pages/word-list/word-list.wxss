.page { padding: 24rpx; background: #f5f7fb; min-height: 100vh; }
.header { padding: 28rpx 24rpx; background: linear-gradient(135deg, #4f46e5 0%, #1d4ed8 100%); color: #fff; border-radius: 24rpx; margin-bottom: 24rpx; }
.header__title { font-size: 38rpx; font-weight: 700; }
.header__sub { margin-top: 10rpx; font-size: 24rpx; opacity: .9; }
.action-bar { margin-bottom: 20rpx; }
.btn { background: #4f46e5; color: #fff; border-radius: 16rpx; font-size: 26rpx; }
.word-list { display: flex; flex-direction: column; gap: 18rpx; }
.word-card { background: #fff; border-radius: 20rpx; padding: 22rpx; box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, .06); }
.word-card__word { font-size: 32rpx; font-weight: 700; color: #111827; }
.word-card__trans { margin-top: 8rpx; color: #4f46e5; font-size: 26rpx; }
.word-card__extra { margin-top: 10rpx; color: #64748b; font-size: 22rpx; line-height: 1.6; }
