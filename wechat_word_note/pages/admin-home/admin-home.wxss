.admin-page { min-height: 100vh; background: #F3F4F6; padding: 32rpx; }
.top-card { background: linear-gradient(135deg, #4F46E5, #1D4ED8); color: #fff; padding: 32rpx; border-radius: 24rpx; margin-bottom: 24rpx; position: relative; }
.logout-btn { margin-top: 16rpx; background: rgba(255,255,255,.16); color: #fff; border-radius: 14rpx; }
.title { display: block; font-size: 40rpx; font-weight: 800; }
.sub-title { display: block; margin-top: 8rpx; font-size: 24rpx; opacity: .9; }
.tabs { display: flex; gap: 16rpx; margin-bottom: 24rpx; flex-wrap: wrap; }
.tab { flex: 1; min-width: 160rpx; text-align: center; background: #fff; border-radius: 16rpx; padding: 18rpx 0; color: #374151; }
.tab.active { background: #EEF2FF; color: #4F46E5; font-weight: 700; }
.section { margin-top: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: #111827; margin-bottom: 16rpx; }
.user-list { display: flex; flex-direction: column; gap: 16rpx; }
.user-item { background: #fff; padding: 24rpx; border-radius: 18rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.05); display: flex; justify-content: space-between; }
.mini-card, .form-card { background: #fff; padding: 24rpx; border-radius: 18rpx; margin-bottom: 12rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.05); }
.form-card input, .picker { width: 100%; margin-bottom: 16rpx; border: 1rpx solid #E5E7EB; border-radius: 14rpx; padding: 18rpx; background: #fff; }
.back-btn { margin-top: 12rpx; background: #4F46E5; color: #fff; border-radius: 14rpx; }
.dict-desc { margin-top: 8rpx; color: #6B7280; font-size: 24rpx; }
.dict-meta { margin-top: 8rpx; color: #4F46E5; font-size: 22rpx; }
