/* pages/about/about.wxss */
.about-container {
  min-height: 100vh;
  background: #F3F4F6;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 25rpx rgba(118, 75, 162, 0.3);
}

.logo-text {
  font-size: 64rpx;
  font-weight: bold;
  color: white;
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 12rpx;
}

.version {
  font-size: 28rpx;
  color: #6B7280;
  background: #E5E7EB;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.content {
  width: 100%;
  max-width: 600rpx;
  flex: 1;
}

.description {
  background: white;
  padding: 32rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  font-size: 30rpx;
  color: #4B5563;
  line-height: 1.6;
  text-align: center;
  box-shadow: 0 4rpx 6rpx rgba(0, 0, 0, 0.05);
}

.description text {
  display: block;
  margin-bottom: 16rpx;
}

.description text:last-child {
  margin-bottom: 0;
}

.contact-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 6rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  border-left: 8rpx solid #667eea;
}

.contact-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-item:active {
  opacity: 0.7;
}

.contact-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.icon {
  font-size: 40rpx;
  margin-right: 24rpx;
  width: 60rpx;
  text-align: center;
}

.contact-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow: hidden;
}

.label {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 4rpx;
}

.value {
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
}

.value.email {
  font-size: 26rpx;
  word-break: break-all;
}

.copy-btn {
  font-size: 24rpx;
  color: #4F46E5;
  background: #EEF2FF;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  margin-left: 24rpx;
  flex-shrink: 0;
}

.footer {
  margin-top: 64rpx;
  text-align: center;
}

.footer text {
  font-size: 24rpx;
  color: #D1D5DB;
}
