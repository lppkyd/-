.page { padding: 24rpx; background: #f5f7fb; min-height: 100vh; }
.header { padding: 28rpx 24rpx; background: linear-gradient(135deg, #4f46e5 0%, #1d4ed8 100%); color: #fff; border-radius: 24rpx; margin-bottom: 24rpx; }
.header__title { font-size: 38rpx; font-weight: 700; }
.header__sub { margin-top: 10rpx; font-size: 24rpx; opacity: .9; }
.section { margin-bottom: 28rpx; }
.section__title { font-size: 30rpx; font-weight: 700; margin-bottom: 18rpx; color: #1f2937; }
.card-list { display: flex; flex-direction: column; gap: 18rpx; }
.dict-card { background: #fff; border-radius: 20rpx; padding: 22rpx; box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, .06); }
.dict-card__name { font-size: 30rpx; font-weight: 700; color: #111827; }
.dict-card__desc { margin-top: 8rpx; color: #64748b; font-size: 24rpx; }
.dict-card__meta { margin-top: 12rpx; color: #4f46e5; font-size: 22rpx; }
.dict-card--custom { border: 1rpx solid #dbe3f0; }
