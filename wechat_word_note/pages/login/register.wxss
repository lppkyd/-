.login-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #4F46E5, #1D4ED8); padding: 32rpx; }
.login-card { width: 100%; background: #fff; border-radius: 24rpx; padding: 36rpx; box-shadow: 0 18rpx 60rpx rgba(0,0,0,.18); }
.title { display: block; font-size: 42rpx; font-weight: 800; color: #111827; }
.sub-title { display: block; margin-top: 8rpx; color: #6B7280; font-size: 24rpx; }
.role-tabs { display: flex; gap: 16rpx; margin: 24rpx 0; }
.role-tab { flex: 1; text-align: center; padding: 16rpx 0; border-radius: 16rpx; background: #F3F4F6; color: #374151; }
.role-tab.active { background: #EEF2FF; color: #4F46E5; font-weight: 700; }
.input { margin-top: 16rpx; width: 100%; border: 1rpx solid #E5E7EB; border-radius: 16rpx; padding: 20rpx 18rpx; }
.btn { margin-top: 24rpx; background: #4F46E5; color: #fff; border-radius: 16rpx; }
.btn--ghost { background: #fff; color: #4F46E5; border: 1rpx solid #C7D2FE; }
