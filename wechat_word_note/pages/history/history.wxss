.history-container { min-height: 100vh; background: #F3F4F6; padding: 32rpx; }
.header { margin-bottom: 24rpx; }
.title { display: block; font-size: 40rpx; font-weight: 700; color: #111827; }
.sub-title { display: block; margin-top: 8rpx; font-size: 24rpx; color: #6B7280; }
.history-list { display: flex; flex-direction: column; gap: 20rpx; }
.history-card { background: #fff; border-radius: 20rpx; padding: 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.05); }
.history-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.dict-name { font-size: 32rpx; font-weight: 700; color: #111827; }
.accuracy { font-size: 30rpx; color: #16A34A; font-weight: 800; }
.history-row { display: flex; justify-content: space-between; padding: 10rpx 0; font-size: 24rpx; color: #475569; }
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 32rpx; }
.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: #6B7280; font-weight: 500; margin-bottom: 12rpx; }
.empty-hint { font-size: 26rpx; color: #9CA3AF; }
